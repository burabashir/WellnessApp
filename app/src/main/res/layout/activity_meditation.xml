<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E0F2F1"
    tools:context=".MeditationActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header with gradient background -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@android:drawable/dialog_holo_light_frame"
            android:backgroundTint="#00796B"
            android:padding="20dp"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✨ Find Your Inner Peace"
                android:textColor="#B2DFDB"
                android:textSize="14sp"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp"
                android:background="@android:drawable/dialog_holo_light_frame"
                android:backgroundTint="#33FFFFFF"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Meditation"
                android:textSize="42sp"
                android:textAlignment="center"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Transform your mind, reduce stress, and discover the power of mindful presence"
                android:textSize="16sp"
                android:textAlignment="center"
                android:textColor="#B2DFDB"
                android:lineSpacingExtra="4dp"
                android:layout_marginBottom="20dp"/>

        </LinearLayout>

        <!-- Hero Image -->
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="300dp"
            android:src="@drawable/meditationimages"
            android:scaleType="centerCrop"
            android:contentDescription="Meditation Image"/>

        <!-- Section Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Meditation Practices"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="#004D40"
            android:textAlignment="center"
            android:padding="20dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Explore 10 powerful techniques to calm your mind and restore balance"
            android:textSize="16sp"
            android:textColor="#00796B"
            android:textAlignment="center"
            android:paddingHorizontal="20dp"
            android:paddingBottom="20dp"/>

        <!-- Meditation Cards -->

        <!-- Card 1: Deep Breathing -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_margin="12dp"
            android:padding="20dp"
            android:background="@android:drawable/dialog_holo_light_frame"
            android:backgroundTint="@android:color/white"
            android:elevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:text="🌬️"
                    android:textSize="32sp"
                    android:gravity="center"
                    android:background="@android:drawable/dialog_holo_light_frame"
                    android:backgroundTint="#E0F2F1"
                    android:layout_marginEnd="12dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Deep Breathing"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#004D40"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⏱ 5 min"
                        android:textSize="14sp"
                        android:textColor="#00897B"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Focus on your breath to calm the nervous system."
                android:textSize="16sp"
                android:textColor="#00796B"
                android:lineSpacingExtra="4dp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:background="#26A69A"
                android:layout_marginTop="12dp"/>
        </LinearLayout>

        <!-- Card 2: Body Scan -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_margin="12dp"
            android:padding="20dp"
            android:background="@android:drawable/dialog_holo_light_frame"
            android:backgroundTint="@android:color/white"
            android:elevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:text="🧘"
                    android:textSize="32sp"
                    android:gravity="center"
                    android:background="@android:drawable/dialog_holo_light_frame"
                    android:backgroundTint="#E0F2F1"
                    android:layout_marginEnd="12dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Body Scan"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#004D40"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⏱ 10 min"
                        android:textSize="14sp"
                        android:textColor="#00897B"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Slowly focus on relaxing each part of your body."
                android:textSize="16sp"
                android:textColor="#00796B"
                android:lineSpacingExtra="4dp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:background="#66BB6A"
                android:layout_marginTop="12dp"/>
        </LinearLayout>

        <!-- Card 3: Mindful Observation -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_margin="12dp"
            android:padding="20dp"
            android:background="@android:drawable/dialog_holo_light_frame"
            android:backgroundTint="@android:color/white"
            android:elevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:text="👁️"
                    android:textSize="32sp"
                    android:gravity="center"
                    android:background="@android:drawable/dialog_holo_light_frame"
                    android:backgroundTint="#E0F2F1"
                    android:layout_marginEnd="12dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Mindful Observation"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#004D40"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⏱ 5 min"
                        android:textSize="14sp"
                        android:textColor="#00897B"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Pick an object and focus on it for a few minutes."
                android:textSize="16sp"
                android:textColor="#00796B"
                android:lineSpacingExtra="4dp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:background="#00BCD4"
                android:layout_marginTop="12dp"/>
        </LinearLayout>

        <!-- Card 4: Guided Imagery -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_margin="12dp"
            android:padding="20dp"
            android:background="@android:drawable/dialog_holo_light_frame"
            android:backgroundTint="@android:color/white"
            android:elevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:text="🌄"
                    android:textSize="32sp"
                    android:gravity="center"
                    android:background="@android:drawable/dialog_holo_light_frame"
                    android:backgroundTint="#E0F2F1"
                    android:layout_marginEnd="12dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Guided Imagery"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#004D40"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⏱ 8 min"
                        android:textSize="14sp"
                        android:textColor="#00897B"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Visualize a peaceful place to reduce anxiety."
                android:textSize="16sp"
                android:textColor="#00796B"
                android:lineSpacingExtra="4dp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:background="#26A69A"
                android:layout_marginTop="12dp"/>
        </LinearLayout>

        <!-- Card 5: Loving-Kindness -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_margin="12dp"
            android:padding="20dp"
            android:background="@android:drawable/dialog_holo_light_frame"
            android:backgroundTint="@android:color/white"
            android:elevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:text="💚"
                    android:textSize="32sp"
                    android:gravity="center"
                    android:background="@android:drawable/dialog_holo_light_frame"
                    android:backgroundTint="#E0F2F1"
                    android:layout_marginEnd="12dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Loving-Kindness"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#004D40"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⏱ 12 min"
                        android:textSize="14sp"
                        android:textColor="#00897B"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Direct positive thoughts toward yourself and others."
                android:textSize="16sp"
                android:textColor="#00796B"
                android:lineSpacingExtra="4dp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:background="#66BB6A"
                android:layout_marginTop="12dp"/>
        </LinearLayout>

        <!-- Card 6: Zen Meditation -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_margin="12dp"
            android:padding="20dp"
            android:background="@android:drawable/dialog_holo_light_frame"
            android:backgroundTint="@android:color/white"
            android:elevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:text="🪷"
                    android:textSize="32sp"
                    android:gravity="center"
                    android:background="@android:drawable/dialog_holo_light_frame"
                    android:backgroundTint="#E0F2F1"
                    android:layout_marginEnd="12dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Zen Meditation"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#004D40"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⏱ 15 min"
                        android:textSize="14sp"
                        android:textColor="#00897B"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Sit in silence and observe thoughts without judgment."
                android:textSize="16sp"
                android:textColor="#00796B"
                android:lineSpacingExtra="4dp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:background="#00BCD4"
                android:layout_marginTop="12dp"/>
        </LinearLayout>

        <!-- Card 7: Walking Meditation -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_margin="12dp"
            android:padding="20dp"
            android:background="@android:drawable/dialog_holo_light_frame"
            android:backgroundTint="@android:color/white"
            android:elevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:text="🚶"
                    android:textSize="32sp"
                    android:gravity="center"
                    android:background="@android:drawable/dialog_holo_light_frame"
                    android:backgroundTint="#E0F2F1"
                    android:layout_marginEnd="12dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Walking Meditation"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#004D40"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⏱ 10 min"
                        android:textSize="14sp"
                        android:textColor="#00897B"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Pay attention to the sensation of your feet on the ground."
                android:textSize="16sp"
                android:textColor="#00796B"
                android:lineSpacingExtra="4dp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:background="#26A69A"
                android:layout_marginTop="12dp"/>
        </LinearLayout>

        <!-- Card 8: Mantra Meditation -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_margin="12dp"
            android:padding="20dp"
            android:background="@android:drawable/dialog_holo_light_frame"
            android:backgroundTint="@android:color/white"
            android:elevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:text="🕉️"
                    android:textSize="32sp"
                    android:gravity="center"
                    android:background="@android:drawable/dialog_holo_light_frame"
                    android:backgroundTint="#E0F2F1"
                    android:layout_marginEnd="12dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Mantra Meditation"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#004D40"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⏱ 10 min"
                        android:textSize="14sp"
                        android:textColor="#00897B"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Repeat a calming word or sound to stay focused."
                android:textSize="16sp"
                android:textColor="#00796B"
                android:lineSpacingExtra="4dp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:background="#66BB6A"
                android:layout_marginTop="12dp"/>
        </LinearLayout>

        <!-- Card 9: Progressive Relaxation -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_margin="12dp"
            android:padding="20dp"
            android:background="@android:drawable/dialog_holo_light_frame"
            android:backgroundTint="@android:color/white"
            android:elevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:text="✨"
                    android:textSize="32sp"
                    android:gravity="center"
                    android:background="@android:drawable/dialog_holo_light_frame"
                    android:backgroundTint="#E0F2F1"
                    android:layout_marginEnd="12dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Progressive Relaxation"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#004D40"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⏱ 12 min"
                        android:textSize="14sp"
                        android:textColor="#00897B"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tense and release muscle groups to shed stress."
                android:textSize="16sp"
                android:textColor="#00796B"
                android:lineSpacingExtra="4dp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:background="#00BCD4"
                android:layout_marginTop="12dp"/>
        </LinearLayout>

        <!-- Card 10: Digital Detox -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_margin="12dp"
            android:padding="20dp"
            android:background="@android:drawable/dialog_holo_light_frame"
            android:backgroundTint="@android:color/white"
            android:elevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:text="📵"
                    android:textSize="32sp"
                    android:gravity="center"
                    android:background="@android:drawable/dialog_holo_light_frame"
                    android:backgroundTint="#E0F2F1"
                    android:layout_marginEnd="12dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Digital Detox"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#004D40"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⏱ 30 min"
                        android:textSize="14sp"
                        android:textColor="#00897B"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Turn off all screens to allow your mind to rest."
                android:textSize="16sp"
                android:textColor="#00796B"
                android:lineSpacingExtra="4dp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:background="#26A69A"
                android:layout_marginTop="12dp"/>
        </LinearLayout>

    </LinearLayout>

</ScrollView>