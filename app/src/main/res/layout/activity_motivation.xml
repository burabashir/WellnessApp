<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF8E1">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:gravity="center"
            android:background="#FF8A65">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💪 Daily Motivation"
                android:textColor="#FFF3E0"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Inspire &amp; Grow"
                android:textSize="42sp"
                android:textAlignment="center"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Boost your motivation every day with simple, actionable tips."
                android:textSize="16sp"
                android:textAlignment="center"
                android:textColor="#FFF3E0"
                android:lineSpacingExtra="4dp"
                android:layout_marginBottom="20dp"/>
        </LinearLayout>

        <!-- Hero Image -->
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="300dp"
            android:src="@drawable/motivationimage"
            android:scaleType="centerCrop"
            android:contentDescription="Motivation Image"/>

        <!-- Section Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Top 10 Motivation Tips"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="#E65100"
            android:textAlignment="center"
            android:padding="20dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Simple strategies to stay focused, positive, and inspired every day"
            android:textSize="16sp"
            android:textColor="#EF6C00"
            android:textAlignment="center"
            android:paddingHorizontal="20dp"
            android:paddingBottom="20dp"/>

        <!-- Motivation Cards -->
        <!-- Tip 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_margin="12dp"
            android:padding="20dp"
            android:background="#FFFFFF"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🐾 Start Small"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#E65100"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Every big journey begins with a single step."
                android:textSize="14sp"
                android:textColor="#EF6C00"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- Tip 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_margin="12dp"
            android:padding="20dp"
            android:background="#FFFFFF"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🌟 Believe in Yourself"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#E65100"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Confidence is the first secret to achieving success."
                android:textSize="14sp"
                android:textColor="#EF6C00"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- Tip 3 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_margin="12dp"
            android:padding="20dp"
            android:background="#FFFFFF"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🧭 Set Clear Goals"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#E65100"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Define what you want to achieve and plan actionable steps."
                android:textSize="14sp"
                android:textColor="#EF6C00"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- Tip 4 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_margin="12dp"
            android:padding="20dp"
            android:background="#FFFFFF"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🎉 Celebrate Wins"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#E65100"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Reward yourself for small achievements along the way."
                android:textSize="14sp"
                android:textColor="#EF6C00"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- Tip 5 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_margin="12dp"
            android:padding="20dp"
            android:background="#FFFFFF"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💡 Learn From Failure"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#E65100"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mistakes are lessons; use them to grow stronger."
                android:textSize="14sp"
                android:textColor="#EF6C00"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- Tip 6 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_margin="12dp"
            android:padding="20dp"
            android:background="#FFFFFF"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🌈 Surround Yourself With Positivity"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#E65100"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Connect with people and environments that lift you up."
                android:textSize="14sp"
                android:textColor="#EF6C00"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- Tip 7 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_margin="12dp"
            android:padding="20dp"
            android:background="#FFFFFF"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⏱️ Stay Consistent"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#E65100"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Consistency compounds results over time."
                android:textSize="14sp"
                android:textColor="#EF6C00"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- Tip 8 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_margin="12dp"
            android:padding="20dp"
            android:background="#FFFFFF"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🎯 Visualize Success"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#E65100"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Picture your goals clearly to stay motivated."
                android:textSize="14sp"
                android:textColor="#EF6C00"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- Tip 9 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_margin="12dp"
            android:padding="20dp"
            android:background="#FFFFFF"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🛌 Take Breaks"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#E65100"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rest and recharge to maintain focus and energy."
                android:textSize="14sp"
                android:textColor="#EF6C00"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- Tip 10 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_margin="12dp"
            android:padding="20dp"
            android:background="#FFFFFF"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📝 Reflect Daily"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#E65100"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Review your progress and adjust your goals each day."
                android:textSize="14sp"
                android:textColor="#EF6C00"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>