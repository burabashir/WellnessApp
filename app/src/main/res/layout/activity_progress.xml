<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#ECEFF1">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#607D8B"
            android:padding="20dp"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📈 Track Your Journey"
                android:textColor="#ECEFF1"
                android:textSize="14sp"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Progress Tracking"
                android:textSize="42sp"
                android:textStyle="bold"
                android:textAlignment="center"
                android:textColor="@android:color/white"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Monitor your progress, celebrate milestones, and adjust your routines for maximum success."
                android:textSize="16sp"
                android:textAlignment="center"
                android:textColor="#ECEFF1"
                android:lineSpacingExtra="4dp"
                android:layout_marginBottom="20dp"/>
        </LinearLayout>

        <!-- Hero Image -->
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="300dp"
            android:src="@drawable/progressimage"
            android:scaleType="centerCrop"
            android:contentDescription="Progress Image"/>

        <!-- Section Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tips for Tracking Progress"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="#37474F"
            android:textAlignment="center"
            android:padding="20dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="10 Guidelines to Monitor Your Fitness and Growth Effectively"
            android:textSize="16sp"
            android:textColor="#607D8B"
            android:textAlignment="center"
            android:paddingHorizontal="20dp"
            android:paddingBottom="20dp"/>

        <!-- Tip 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_margin="12dp"
            android:padding="20dp"
            android:background="#FFFFFF"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚖️ Monitor Weight Changes"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#37474F"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Keep a weekly log of your weight to see long-term trends and adjust your routines accordingly."
                android:textSize="16sp"
                android:textColor="#607D8B"
                android:layout_marginTop="4dp"
                android:lineSpacingExtra="4dp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:background="#455A64"
                android:layout_marginTop="12dp"/>
        </LinearLayout>

        <!-- Tip 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_margin="12dp"
            android:padding="20dp"
            android:background="#FFFFFF"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📏 Body Measurements"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#37474F"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Monitor waist, hip, and arm measurements for a clearer view of your body composition over time."
                android:textSize="16sp"
                android:textColor="#607D8B"
                android:layout_marginTop="4dp"
                android:lineSpacingExtra="4dp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:background="#78909C"
                android:layout_marginTop="12dp"/>
        </LinearLayout>

        <!-- Tip 3 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_margin="12dp"
            android:padding="20dp"
            android:background="#FFFFFF"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📅 Track Workouts"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#37474F"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Record exercises, sets, and reps to monitor progress and increase performance."
                android:textSize="16sp"
                android:textColor="#607D8B"
                android:layout_marginTop="4dp"
                android:lineSpacingExtra="4dp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:background="#455A64"
                android:layout_marginTop="12dp"/>
        </LinearLayout>

        <!-- Tip 4 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_margin="12dp"
            android:padding="20dp"
            android:background="#FFFFFF"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📝 Keep a Journal"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#37474F"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Document moods, energy, and sleep patterns to identify patterns impacting your fitness."
                android:textSize="16sp"
                android:textColor="#607D8B"
                android:layout_marginTop="4dp"
                android:lineSpacingExtra="4dp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:background="#78909C"
                android:layout_marginTop="12dp"/>
        </LinearLayout>

        <!-- Tip 5 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_margin="12dp"
            android:padding="20dp"
            android:background="#FFFFFF"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🥗 Track Nutrition"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#37474F"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Log meals, calories, and macros to see how nutrition affects your progress."
                android:textSize="16sp"
                android:textColor="#607D8B"
                android:layout_marginTop="4dp"
                android:lineSpacingExtra="4dp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:background="#455A64"
                android:layout_marginTop="12dp"/>
        </LinearLayout>

        <!-- Tip 6 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_margin="12dp"
            android:padding="20dp"
            android:background="#FFFFFF"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⏱️ Track Time"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#37474F"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Record workout durations and rest times to optimize efficiency and results."
                android:textSize="16sp"
                android:textColor="#607D8B"
                android:layout_marginTop="4dp"
                android:lineSpacingExtra="4dp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:background="#78909C"
                android:layout_marginTop="12dp"/>
        </LinearLayout>

        <!-- Tip 7 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_margin="12dp"
            android:padding="20dp"
            android:background="#FFFFFF"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🏃‍♂️ Track Cardio"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#37474F"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Monitor runs, steps, and heart rate to track endurance improvements."
                android:textSize="16sp"
                android:textColor="#607D8B"
                android:layout_marginTop="4dp"
                android:lineSpacingExtra="4dp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:background="#455A64"
                android:layout_marginTop="12dp"/>
        </LinearLayout>

        <!-- Tip 8 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_margin="12dp"
            android:padding="20dp"
            android:background="#FFFFFF"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🛌 Track Sleep"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#37474F"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Monitor sleep duration and quality to understand recovery and energy levels."
                android:textSize="16sp"
                android:textColor="#607D8B"
                android:layout_marginTop="4dp"
                android:lineSpacingExtra="4dp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:background="#78909C"
                android:layout_marginTop="12dp"/>
        </LinearLayout>

        <!-- Tip 9 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_margin="12dp"
            android:padding="20dp"
            android:background="#FFFFFF"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📊 Review Progress Weekly"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#37474F"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Analyze trends weekly to identify what’s working and what needs adjustment."
                android:textSize="16sp"
                android:textColor="#607D8B"
                android:layout_marginTop="4dp"
                android:lineSpacingExtra="4dp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:background="#455A64"
                android:layout_marginTop="12dp"/>
        </LinearLayout>

        <!-- Tip 10 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_margin="12dp"
            android:padding="20dp"
            android:background="#FFFFFF"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🎯 Set Goals"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#37474F"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Define clear, measurable goals to guide your progress and stay motivated."
                android:textSize="16sp"
                android:textColor="#607D8B"
                android:layout_marginTop="4dp"
                android:lineSpacingExtra="4dp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:background="#78909C"
                android:layout_marginTop="12dp"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>