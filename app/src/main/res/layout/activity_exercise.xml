<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E3F2FD">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@android:drawable/dialog_holo_light_frame"
            android:backgroundTint="#0D47A1"
            android:padding="20dp"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💪 Stay Fit &amp; Strong"
                android:textColor="#BBDEFB"
                android:textSize="14sp"
                android:padding="8dp"
                android:background="@android:drawable/dialog_holo_light_frame"
                android:backgroundTint="#33FFFFFF"
                android:layout_marginBottom="10dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Exercise"
                android:textSize="40sp"
                android:textStyle="bold"
                android:textAlignment="center"
                android:textColor="@android:color/white"/>
        </LinearLayout>

        <!-- Hero Image -->
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="250dp"
            android:src="@drawable/exerciseimage"
            android:scaleType="centerCrop"/>

        <!-- Section Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Workout Routines"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#0D47A1"
            android:textAlignment="center"
            android:padding="20dp"/>

        <!-- Cards 1 to 10 -->
        <!-- Card 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_margin="12dp"
            android:padding="20dp"
            android:background="@android:drawable/dialog_holo_light_frame"
            android:backgroundTint="@android:color/white"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🚶 Brisk Walking"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#0D47A1"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="A 30-minute walk to improve heart health."
                android:textSize="16sp"
                android:textColor="#1976D2"
                android:layout_marginTop="8dp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:background="#42A5F5"
                android:layout_marginTop="10dp"/>
        </LinearLayout>

        <!-- Card 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_margin="12dp"
            android:padding="20dp"
            android:background="@android:drawable/dialog_holo_light_frame"
            android:backgroundTint="@android:color/white"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💪 Push-Ups"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#0D47A1"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Strengthens chest, shoulders, and triceps."
                android:textSize="16sp"
                android:textColor="#1976D2"
                android:layout_marginTop="8dp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:background="#1E88E5"
                android:layout_marginTop="10dp"/>
        </LinearLayout>

        <!-- Card 3 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_margin="12dp"
            android:padding="20dp"
            android:background="@android:drawable/dialog_holo_light_frame"
            android:backgroundTint="@android:color/white"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🏋️ Squats"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#0D47A1"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Builds leg strength and core stability."
                android:textSize="16sp"
                android:textColor="#1976D2"
                android:layout_marginTop="8dp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:background="#64B5F6"
                android:layout_marginTop="10dp"/>
        </LinearLayout>

        <!-- Card 4 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_margin="12dp"
            android:padding="20dp"
            android:background="@android:drawable/dialog_holo_light_frame"
            android:backgroundTint="@android:color/white"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🏃‍♂️ Jogging"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#0D47A1"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="A 20-minute jog to boost endurance."
                android:textSize="16sp"
                android:textColor="#1976D2"
                android:layout_marginTop="8dp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:background="#2196F3"
                android:layout_marginTop="10dp"/>
        </LinearLayout>

        <!-- Card 5 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_margin="12dp"
            android:padding="20dp"
            android:background="@android:drawable/dialog_holo_light_frame"
            android:backgroundTint="@android:color/white"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🤸‍♂️ Plank"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#0D47A1"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Strengthens the core muscles."
                android:textSize="16sp"
                android:textColor="#1976D2"
                android:layout_marginTop="8dp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:background="#1E88E5"
                android:layout_marginTop="10dp"/>
        </LinearLayout>

        <!-- Card 6 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_margin="12dp"
            android:padding="20dp"
            android:background="@android:drawable/dialog_holo_light_frame"
            android:backgroundTint="@android:color/white"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🧘 Yoga"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#0D47A1"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Improves flexibility and reduces stress."
                android:textSize="16sp"
                android:textColor="#1976D2"
                android:layout_marginTop="8dp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:background="#64B5F6"
                android:layout_marginTop="10dp"/>
        </LinearLayout>

        <!-- Card 7 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_margin="12dp"
            android:padding="20dp"
            android:background="@android:drawable/dialog_holo_light_frame"
            android:backgroundTint="@android:color/white"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🏋️ Deadlift"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#0D47A1"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Builds overall strength and posture."
                android:textSize="16sp"
                android:textColor="#1976D2"
                android:layout_marginTop="8dp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:background="#2196F3"
                android:layout_marginTop="10dp"/>
        </LinearLayout>

        <!-- Card 8 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_margin="12dp"
            android:padding="20dp"
            android:background="@android:drawable/dialog_holo_light_frame"
            android:backgroundTint="@android:color/white"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🏃 Lunges"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#0D47A1"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Strengthens legs and glutes."
                android:textSize="16sp"
                android:textColor="#1976D2"
                android:layout_marginTop="8dp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:background="#42A5F5"
                android:layout_marginTop="10dp"/>
        </LinearLayout>

        <!-- Card 9 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_margin="12dp"
            android:padding="20dp"
            android:background="@android:drawable/dialog_holo_light_frame"
            android:backgroundTint="@android:color/white"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🤸 Burpees"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#0D47A1"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="A full-body exercise for strength and cardio."
                android:textSize="16sp"
                android:textColor="#1976D2"
                android:layout_marginTop="8dp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:background="#1E88E5"
                android:layout_marginTop="10dp"/>
        </LinearLayout>

        <!-- Card 10 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_margin="12dp"
            android:padding="20dp"
            android:background="@android:drawable/dialog_holo_light_frame"
            android:backgroundTint="@android:color/white"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🏋️‍♂️ Bench Press"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#0D47A1"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Strengthens chest, arms, and shoulders."
                android:textSize="16sp"
                android:textColor="#1976D2"
                android:layout_marginTop="8dp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:background="#64B5F6"
                android:layout_marginTop="10dp"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>