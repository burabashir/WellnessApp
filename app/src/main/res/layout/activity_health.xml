<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F9FC">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#0D47A1"
            android:padding="20dp"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Eat Healthy, Stay Fit"
                android:textColor="#BBDEFB"
                android:textSize="14sp"
                android:layout_marginBottom="10dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Healthy Recipes"
                android:textSize="36sp"
                android:textStyle="bold"
                android:textAlignment="center"
                android:textColor="@android:color/white"/>
        </LinearLayout>

        <!-- Hero Image -->
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="250dp"
            android:src="@drawable/image6"
            android:scaleType="centerCrop"/>

        <!-- Section Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Top 10 Recipes"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#0D47A1"
            android:textAlignment="center"
            android:padding="20dp"/>

        <!-- Recipe Cards -->

        <!-- Card 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_margin="12dp"
            android:padding="20dp"
            android:background="#FFFFFF"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Fruit Salad"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#0D47A1"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="A mix of fresh fruits like bananas, apples, and oranges."
                android:textSize="16sp"
                android:textColor="#1976D2"
                android:layout_marginTop="8dp"/>
        </LinearLayout>

        <!-- Card 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_margin="12dp"
            android:padding="20dp"
            android:background="#FFFFFF"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Grilled Chicken"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#0D47A1"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Low-fat grilled chicken served with vegetables."
                android:textSize="16sp"
                android:textColor="#1976D2"
                android:layout_marginTop="8dp"/>
        </LinearLayout>

        <!-- Card 3 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_margin="12dp"
            android:padding="20dp"
            android:background="#FFFFFF"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Vegetable Stir Fry"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#0D47A1"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Carrots, broccoli, and peppers cooked lightly."
                android:textSize="16sp"
                android:textColor="#1976D2"
                android:layout_marginTop="8dp"/>
        </LinearLayout>

        <!-- Card 4 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_margin="12dp"
            android:padding="20dp"
            android:background="#FFFFFF"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Quinoa Salad"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#0D47A1"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="A healthy salad with quinoa, veggies, and olive oil dressing."
                android:textSize="16sp"
                android:textColor="#1976D2"
                android:layout_marginTop="8dp"/>
        </LinearLayout>

        <!-- Card 5 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_margin="12dp"
            android:padding="20dp"
            android:background="#FFFFFF"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Oatmeal Breakfast"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#0D47A1"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Warm oatmeal topped with berries and nuts."
                android:textSize="16sp"
                android:textColor="#1976D2"
                android:layout_marginTop="8dp"/>
        </LinearLayout>

        <!-- Card 6 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_margin="12dp"
            android:padding="20dp"
            android:background="#FFFFFF"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Smoothie Bowl"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#0D47A1"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Blend fruits and yogurt, topped with granola."
                android:textSize="16sp"
                android:textColor="#1976D2"
                android:layout_marginTop="8dp"/>
        </LinearLayout>

        <!-- Card 7 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_margin="12dp"
            android:padding="20dp"
            android:background="#FFFFFF"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Grilled Fish"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#0D47A1"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Seasoned fish grilled with a side of vegetables."
                android:textSize="16sp"
                android:textColor="#1976D2"
                android:layout_marginTop="8dp"/>
        </LinearLayout>

        <!-- Card 8 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_margin="12dp"
            android:padding="20dp"
            android:background="#FFFFFF"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Greek Yogurt Parfait"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#0D47A1"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Layered yogurt with fruits and honey."
                android:textSize="16sp"
                android:textColor="#1976D2"
                android:layout_marginTop="8dp"/>
        </LinearLayout>

        <!-- Card 9 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_margin="12dp"
            android:padding="20dp"
            android:background="#FFFFFF"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Avocado Toast"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#0D47A1"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Whole-grain toast with mashed avocado and spices."
                android:textSize="16sp"
                android:textColor="#1976D2"
                android:layout_marginTop="8dp"/>
        </LinearLayout>

        <!-- Card 10 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_margin="12dp"
            android:padding="20dp"
            android:background="#FFFFFF"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chia Seed Pudding"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#0D47A1"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Chia seeds soaked overnight in almond milk with fruits."
                android:textSize="16sp"
                android:textColor="#1976D2"
                android:layout_marginTop="8dp"/>
        </LinearLayout>

    </LinearLayout>

</ScrollView>