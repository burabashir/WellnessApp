<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F9FBE7">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#8BC34A"
            android:padding="20dp"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🥗 Nourish Your Body"
                android:textColor="#DCEDC8"
                android:textSize="14sp"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Nutrition"
                android:textSize="42sp"
                android:textAlignment="center"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Learn essential tips to eat healthy, balance your diet, and fuel your body effectively."
                android:textSize="16sp"
                android:textAlignment="center"
                android:textColor="#DCEDC8"
                android:lineSpacingExtra="4dp"
                android:layout_marginBottom="20dp"/>
        </LinearLayout>

        <!-- Hero Image -->
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="300dp"
            android:src="@drawable/nutritionimage"
            android:scaleType="centerCrop"
            android:contentDescription="Nutrition Image"/>

        <!-- Section Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nutrition Tips"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="#33691E"
            android:textAlignment="center"
            android:padding="20dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="10 Key Guidelines to Eat Healthily and Boost Your Energy"
            android:textSize="16sp"
            android:textColor="#558B2F"
            android:textAlignment="center"
            android:paddingHorizontal="20dp"
            android:paddingBottom="20dp"/>

        <!-- Nutrition Tip Card Template -->
        <!-- Tip 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_margin="12dp"
            android:padding="20dp"
            android:background="#FFFFFF"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🍽️ Eat Balanced Meals"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#33691E"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Include proteins, healthy fats, and complex carbs in every meal for proper nourishment."
                android:textSize="16sp"
                android:textColor="#558B2F"
                android:layout_marginTop="4dp"
                android:lineSpacingExtra="4dp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:background="#8BC34A"
                android:layout_marginTop="12dp"/>
        </LinearLayout>

        <!-- Tip 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_margin="12dp"
            android:padding="20dp"
            android:background="#FFFFFF"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🌾 Prioritize Whole Foods"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#33691E"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Choose natural, unprocessed foods over packaged items for optimal health."
                android:textSize="16sp"
                android:textColor="#558B2F"
                android:layout_marginTop="4dp"
                android:lineSpacingExtra="4dp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:background="#689F38"
                android:layout_marginTop="12dp"/>
        </LinearLayout>

        <!-- Tip 3 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_margin="12dp"
            android:padding="20dp"
            android:background="#FFFFFF"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🥦 Increase Fiber Intake"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#33691E"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Eat more beans, lentils, and whole grains for better digestion."
                android:textSize="16sp"
                android:textColor="#558B2F"
                android:layout_marginTop="4dp"
                android:lineSpacingExtra="4dp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:background="#689F38"
                android:layout_marginTop="12dp"/>
        </LinearLayout>

        <!-- Tip 4 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_margin="12dp"
            android:padding="20dp"
            android:background="#FFFFFF"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🥛 Stay Hydrated"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#33691E"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Drink plenty of water and fluids to support metabolism and energy levels."
                android:textSize="16sp"
                android:textColor="#558B2F"
                android:layout_marginTop="4dp"
                android:lineSpacingExtra="4dp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:background="#8BC34A"
                android:layout_marginTop="12dp"/>
        </LinearLayout>

        <!-- Tip 5 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_margin="12dp"
            android:padding="20dp"
            android:background="#FFFFFF"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🍎 Eat Fruits &amp; Vegetables"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#33691E"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Include a variety of colorful fruits and vegetables for essential vitamins and minerals."
                android:textSize="16sp"
                android:textColor="#558B2F"
                android:layout_marginTop="4dp"
                android:lineSpacingExtra="4dp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:background="#689F38"
                android:layout_marginTop="12dp"/>
        </LinearLayout>

        <!-- Tip 6 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_margin="12dp"
            android:padding="20dp"
            android:background="#FFFFFF"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🥜 Include Healthy Fats"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#33691E"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Use nuts, seeds, and olive oil to support heart health."
                android:textSize="16sp"
                android:textColor="#558B2F"
                android:layout_marginTop="4dp"
                android:lineSpacingExtra="4dp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:background="#8BC34A"
                android:layout_marginTop="12dp"/>
        </LinearLayout>

        <!-- Tip 7 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_margin="12dp"
            android:padding="20dp"
            android:background="#FFFFFF"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🍵 Limit Sugar &amp; Salt"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#33691E"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Reduce added sugars and excessive salt for better long-term health."
                android:textSize="16sp"
                android:textColor="#558B2F"
                android:layout_marginTop="4dp"
                android:lineSpacingExtra="4dp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:background="#689F38"
                android:layout_marginTop="12dp"/>
        </LinearLayout>

        <!-- Tip 8 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_margin="12dp"
            android:padding="20dp"
            android:background="#FFFFFF"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🕒 Eat on Schedule"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#33691E"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Maintain regular meal timings to stabilize energy and metabolism."
                android:textSize="16sp"
                android:textColor="#558B2F"
                android:layout_marginTop="4dp"
                android:lineSpacingExtra="4dp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:background="#8BC34A"
                android:layout_marginTop="12dp"/>
        </LinearLayout>

        <!-- Tip 9 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_margin="12dp"
            android:padding="20dp"
            android:background="#FFFFFF"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🥤 Avoid Sugary Drinks"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#33691E"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Replace sodas and sweetened drinks with water, herbal teas, or fresh juices."
                android:textSize="16sp"
                android:textColor="#558B2F"
                android:layout_marginTop="4dp"
                android:lineSpacingExtra="4dp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:background="#689F38"
                android:layout_marginTop="12dp"/>
        </LinearLayout>

        <!-- Tip 10 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_margin="12dp"
            android:padding="20dp"
            android:background="#FFFFFF"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📝 Plan Meals Ahead"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#33691E"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Meal planning helps you make healthier choices and avoid last-minute unhealthy foods."
                android:textSize="16sp"
                android:textColor="#558B2F"
                android:layout_marginTop="4dp"
                android:lineSpacingExtra="4dp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:background="#8BC34A"
                android:layout_marginTop="12dp"/>
        </LinearLayout>

        <!-- Reward Button -->
        <Button
            android:id="@+id/rewardAdd"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Get Reward"
            android:textSize="28sp"
            android:textColor="@android:color/white"
            android:backgroundTint="#33691E"
            android:layout_margin="16dp"
            android:padding="12dp"
            android:elevation="4dp"/>

    </LinearLayout>
</ScrollView>